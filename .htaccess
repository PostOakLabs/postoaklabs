# .htaccess — postoaklabs.com
# Last updated: May 2026
# - Force HTTPS
# - 301 redirects for tools that migrated to AINumbers.co
# - Standard security headers

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Strip "www." (canonical = postoaklabs.com without www)
RewriteCond %{HTTP_HOST} ^www\.postoaklabs\.com$ [NC]
RewriteRule ^(.*)$ https://postoaklabs.com/$1 [L,R=301]

